pragma Singleton
import QtQuick
import Quickshell
import Quickshell.Io

Singleton {
  id: root

  // --- Public Properties ---
  property string type: "disconnected" // disconnected, wifi, ethernet
  property string interfaceName: ""
  property string ipAddress: ""
  property string ssid: ""
  property int signalStrength: 0

  // --- Internal Logic ---
  
  // This process runs a lightweight infinite loop in sh.
  // It reads system files directly for maximum performance.
 property var _netProcrocess {
    id: netProc
    running: true
    
    // Command explanation:
    // 1. Find default interface via ip route.
    // 2. If none, print disconnected.
    // 3. If found, check /sys/class/net for wireless folder to determine type.
    // 4. Read SSID via iwgetid (standard on Arch) and Signal from /proc/net/wireless.
    // 5. Sleep 3 seconds and repeat.
    command: ["sh", "-c", `
      export LC_ALL=C
      while true; do
        dev=$(ip route 2>/dev/null | awk '/^default/ {print $5; exit}')
        
        if [ -z "$dev" ]; then
          echo "disconnected"
        else
          ip=$(ip -4 -o addr show $dev | awk '{print $4}' | cut -d/ -f1)
          
          if [ -d "/sys/class/net/$dev/wireless" ]; then
            id=$(iwgetid -r "$dev")
            # Parse link quality (col 3) from /proc, normalize 70->100%
            sig=$(awk -v d="$dev" '$0 ~ d {print int($3 * 100 / 70)}' /proc/net/wireless)
            echo "wifi|$dev|$ip|$id|$sig"
          else
            echo "ethernet|$dev|$ip||"
          fi
        fi
        sleep 3
      done
    `]

    onStdout: (output) => {
      const lines = output.trim().split("\n")
      // Handle potential buffering where multiple lines arrive at once
      const lastLine = lines[lines.length - 1]
      if (!lastLine) return

      const parts = lastLine.split("|")
      
      if (parts[0] === "disconnected") {
        root.type = "disconnected"
        root.interfaceName = ""
        root.ipAddress = ""
        root.ssid = ""
        root.signalStrength = 0
      } else {
        root.type = parts[0] || "ethernet"
        root.interfaceName = parts[1] || ""
        root.ipAddress = parts[2] || ""
        root.ssid = parts[3] || ""
        // parse signal, cap at 100
        let sig = parseInt(parts[4]) || 0
        root.signalStrength = sig > 100 ? 100 : sig
      }
    }
  }
}
