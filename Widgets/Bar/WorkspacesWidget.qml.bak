import QtQuick
import QtQuick.Layouts
import QtQml
import Quickshell
import Quickshell.Hyprland
import qs.Themes

RowLayout {
    id: root
  spacing: 6

    property int minWorkspaces: 6
    property int maxHyprlandId: 0
    
    // A map (Object) linking IDs to Workspace Objects: { 1: wsObj, 2: wsObj }
    property var workspaceMap: ({})

    // Rectangle {
    //   anchors {
    //     fill: parent
    //     leftMargin: 0
    //     rightMargin: -5
    //     topMargin: -7
    //     bottomMargin: -7
    //   }
    //   color: Theme.alpha(Theme.background, 0.35)
    //   radius: 8
    // }

    // Tracks all active Hyprland workspaces to populate the map and max ID
    Instantiator {
        model: Hyprland.workspaces
        
        delegate: QtObject {
            // "modelData" here is the HyprlandWorkspace object
            property var workspace: modelData
            
            Component.onCompleted: {
                let map = Object.assign({}, root.workspaceMap)
                map[workspace.id] = workspace
                root.workspaceMap = map
                root.recalcMax()
            }
            
            Component.onDestruction: {
                let map = Object.assign({}, root.workspaceMap)
                delete map[workspace.id]
                root.workspaceMap = map
                root.recalcMax()
            }
        }
    }

    function recalcMax() {
        let keys = Object.keys(root.workspaceMap).map(Number)
        if (keys.length === 0) {
            root.maxHyprlandId = 0
        } else {
            root.maxHyprlandId = Math.max(...keys)
        }
    }

    Repeater {
        // Display at least minWorkspaces, or more if a higher ID exists
        model: Math.max(root.minWorkspaces, root.maxHyprlandId)

        delegate: Rectangle {
            id: workspaceIndicator
            
            readonly property int wsId: index + 1
            
            // Retrieve the workspace object from our map. 
            // If undefined, the workspace is empty/inactive.
            property var wsObject: root.workspaceMap[wsId] ?? null

            property bool isFocused: Hyprland.focusedWorkspace && Hyprland.focusedWorkspace.id === wsId
            property bool hasWindows: false

            width: 11
            height: 11
            radius: width / 2

            // Watch window count on the specific workspace object
            Instantiator {
                active: workspaceIndicator.wsObject !== null
                model: workspaceIndicator.wsObject ? workspaceIndicator.wsObject.toplevels : null
                onCountChanged: workspaceIndicator.hasWindows = count > 0
                delegate: QtObject {} 
            }
            
            // Ensure state resets if the workspace object is removed (becomes empty)
            onWsObjectChanged: {
                if (!wsObject) hasWindows = false;
            }

            color: {
                if (isFocused) return Theme.color9
                if (hasWindows) return Theme.alpha(Theme.color9, 0.3)
                return Theme.alpha(Theme.background, 0.5)
            }

            Behavior on color {
              ColorAnimation {
                duration: 200

              }
            }

            // Text {
            //     anchors.centerIn: parent
            //     text: workspaceIndicator.wsId
            //     color: Theme.foreground
            //     font.bold: true
            // }

            MouseArea {
                anchors.fill: parent
                onClicked: Hyprland.dispatch(`workspace ${workspaceIndicator.wsId}`)
                cursorShape: Qt.PointingHandCursor
            }
        }
    }
}


